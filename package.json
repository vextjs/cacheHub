{
  "name": "cache-hub",
  "version": "2.2.0",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "types": "./dist/types/index.d.ts",
  "description": "Zero-runtime-dependency caching and atomic state toolkit for Node.js services.",
  "keywords": [
    "cache",
    "caching",
    "nodejs",
    "typescript",
    "memory-cache",
    "redis",
    "multi-level-cache",
    "lru",
    "ttl",
    "read-through",
    "function-cache",
    "distributed-cache",
    "atomic-counter",
    "atomic-state",
    "rate-limit",
    "fixed-window",
    "sliding-window",
    "token-bucket",
    "leaky-bucket",
    "zero-dependency"
  ],
  "license": "MIT",
  "homepage": "https://github.com/vextjs/cacheHub#readme",
  "bugs": {
    "url": "https://github.com/vextjs/cacheHub/issues"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./multi-level": {
      "types": "./dist/types/multi-level-cache.d.ts",
      "import": "./dist/esm/multi-level-cache.js",
      "require": "./dist/cjs/multi-level-cache.js"
    },
    "./redis": {
      "types": "./dist/types/redis-adapter.d.ts",
      "import": "./dist/esm/redis-adapter.js",
      "require": "./dist/cjs/redis-adapter.js"
    },
    "./function-cache": {
      "types": "./dist/types/function-cache.d.ts",
      "import": "./dist/esm/function-cache.js",
      "require": "./dist/cjs/function-cache.js"
    },
    "./distributed": {
      "types": "./dist/types/distributed-invalidator.d.ts",
      "import": "./dist/esm/distributed-invalidator.js",
      "require": "./dist/cjs/distributed-invalidator.js"
    },
    "./stringify": {
      "types": "./dist/types/stable-stringify.d.ts",
      "import": "./dist/esm/stable-stringify.js",
      "require": "./dist/cjs/stable-stringify.js"
    },
    "./read-through": {
      "types": "./dist/types/read-through.d.ts",
      "import": "./dist/esm/read-through.js",
      "require": "./dist/cjs/read-through.js"
    },
    "./lease": {
      "types": "./dist/types/redis-lease.d.ts",
      "import": "./dist/esm/redis-lease.js",
      "require": "./dist/cjs/redis-lease.js"
    },
    "./atomic": {
      "types": "./dist/types/atomic.d.ts",
      "import": "./dist/esm/atomic.js",
      "require": "./dist/cjs/atomic.js"
    },
    "./rate-limit": {
      "types": "./dist/types/rate-limit.d.ts",
      "import": "./dist/esm/rate-limit.js",
      "require": "./dist/cjs/rate-limit.js"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "changelogs",
    "docs",
    "scripts/benchmark.mjs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vextjs/cacheHub.git"
  },
  "peerDependencies": {
    "ioredis": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "ioredis": "^5.0.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:coverage": "vitest run --config vitest.integration.config.ts --coverage",
    "build": "rimraf dist && npm run build:esm && npm run build:cjs && node -e \"require('fs').writeFileSync('dist/cjs/package.json', JSON.stringify({type:'commonjs'}))\"",
    "build:esm": "tsc -p tsconfig.json",
    "build:cjs": "node scripts/build-cjs.mjs",
    "benchmark": "npm run build && node scripts/benchmark.mjs",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test:coverage && npm run test:integration && npm run build"
  }
}
