{
  "compilerOptions": {
    "strict": true,
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist/esm",
    "declaration": true,
    "declarationDir": "dist/types",
    "rootDir": "src",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": false,
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"],
}
