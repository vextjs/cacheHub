{
  "compilerOptions": {
    "strict": true,
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist/cjs",
    "declaration": false,
    "rootDir": "src",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": false,
    "noEmitOnError": false,
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"],
}
